{
  "manifest_version": 3,
  "name": "Spanish Live Translation",
  "version": "4.0.0",
  "description": "Right-click any highlighted text to translate it live.",
  "permissions": ["contextMenus", "scripting", "activeTab", "storage"],
  "host_permissions": ["https://translate.googleapis.com/*"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "Spanish Live Translation",
    "default_popup": "popup.html"
  }
}
